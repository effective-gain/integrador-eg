{
  "permissions": {
    "allow": [
      "Bash(python -c \"import uvicorn; print\\(uvicorn.__version__\\)\")",
      "Bash(python -m uvicorn api.webhook:app --host 127.0.0.1 --port 8000 --reload)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code} — %{size_download} bytes\\\\n\" http://127.0.0.1:8000/)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code} — /static/app.js\\\\n\" http://127.0.0.1:8000/static/app.js)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code} — /static/style.css\\\\n\" http://127.0.0.1:8000/static/style.css)",
      "Bash(start \"\" \"http://127.0.0.1:8000/\")",
      "Bash(cmd.exe /c start \"\" \"http://127.0.0.1:8000/\")"
    ]
  }
}
