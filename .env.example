# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_INSTANCE=nome-da-instancia
EVOLUTION_API_KEY=sua-chave-aqui

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (Whisper — transcrição de áudio)
OPENAI_API_KEY=sk-...

# Obsidian REST API (porta local 27124)
OBSIDIAN_API_URL=http://localhost:27124
OBSIDIAN_API_KEY=sua-chave-do-plugin

# Gmail (IMAP — use App Password, não a senha real)
GMAIL_USER=seu@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Briefing matinal
BRIEFING_NUMERO_DESTINO=5531999999999  # número WhatsApp que recebe o briefing
BRIEFING_HORA=08:00

# Segurança do webhook (definir o mesmo valor na Evolution API em x-webhook-secret)
WEBHOOK_SECRET=gere-uma-string-aleatoria-segura-aqui

# App
LOG_LEVEL=INFO
ENVIRONMENT=development

# Postgres (usuários do painel web)
DATABASE_URL=postgresql://usuario:senha@localhost:5432/integrador_eg

# Sessão do painel web (string aleatória longa — usada para assinar o cookie)
SESSION_SECRET=troque-por-uma-string-aleatoria-longa
